---
import BaseLayout from "../layouts/BaseLayout.astro";
import ApplicationScripts from "../components/ApplicationScripts.astro";
---

<BaseLayout
  title="Apply to US Fellows"
  description="Submit an application for consideration as a US Fellow and a public-interest fellowship appointment."
  canonical="https://usfellows.org/apply.html"
  activePage="apply"
>
  <main id="main"><header class="page-hero"><div class="container"><div class="breadcrumbs"><a href="index.html">Home</a> / Apply</div><span class="kicker">Fellowship application</span><h1>Apply to US Fellows</h1><p>Tell the Society about your record, your mission, and the contribution you are prepared to make. Required fields are marked with <span aria-hidden="true">*</span><span class="visually-hidden">an asterisk</span>.</p></div></header><section class="section section--mist"><div class="container"><div class="application-shell"><div class="application-progress"><div class="application-progress__meta" aria-live="polite"><span id="application-step-text">Page 1 of 5</span><span id="application-step-name">Identity</span></div><div class="application-progress__track" role="progressbar" aria-label="Application progress" aria-valuemin="1" aria-valuemax="5" aria-valuenow="1" aria-valuetext="Page 1 of 5: Identity"><span class="application-progress__bar" id="application-progress-bar"></span></div></div><form class="application-form" id="fellowship-application" novalidate>
<input type="hidden" name="source_form" value="US Fellows Web Application"><div class="honeypot" aria-hidden="true"><label for="company-website">Leave this field blank</label><input type="text" id="company-website" name="company_website" tabindex="-1" autocomplete="off"></div>
<fieldset class="form-step" data-step="Identity"><legend tabindex="-1">Your identity</legend><p class="form-help">Use the name and contact information by which the Society should identify you.</p><div class="form-grid"><div class="form-field"><label for="first-name">First name <span class="required" aria-hidden="true">*</span></label><input id="first-name" name="first_name" required autocomplete="given-name"><p class="field-error" id="first-name-error">Enter your first name.</p></div><div class="form-field"><label for="middle-name">Middle name <span>(optional)</span></label><input id="middle-name" name="middle_name" autocomplete="additional-name"></div><div class="form-field"><label for="last-name">Last name <span class="required" aria-hidden="true">*</span></label><input id="last-name" name="last_name" required autocomplete="family-name"><p class="field-error" id="last-name-error">Enter your last name.</p></div><div class="form-field"><label for="preferred-name">Preferred name <span>(optional)</span></label><input id="preferred-name" name="preferred_name" autocomplete="nickname"></div><div class="form-field"><label for="email">Email address <span class="required" aria-hidden="true">*</span></label><input type="email" id="email" name="email" required autocomplete="email"><p class="field-error" id="email-error">Enter a valid email address.</p></div><div class="form-field"><label for="phone">Phone <span>(optional)</span></label><input type="tel" id="phone" name="phone" autocomplete="tel"></div><div class="form-field"><label for="city">City <span class="required" aria-hidden="true">*</span></label><input id="city" name="city" required autocomplete="address-level2"><p class="field-error" id="city-error">Enter your city.</p></div><div class="form-field"><label for="state">State, province, or region <span class="required" aria-hidden="true">*</span></label><input id="state" name="state" required autocomplete="address-level1"><p class="field-error" id="state-error">Enter your state, province, or region.</p></div><div class="form-field"><label for="country">Country of residence <span class="required" aria-hidden="true">*</span></label><input id="country" name="country" required autocomplete="country-name"><p class="field-error" id="country-error">Enter your country of residence.</p></div><div class="form-field"><label for="citizenship-country">Country of citizenship <span>(optional)</span></label><input id="citizenship-country" name="citizenship_country"></div></div></fieldset>
<fieldset class="form-step" data-step="Fellowship direction" hidden><legend tabindex="-1">Your fellowship direction</legend><p class="form-help">Choose the program and missions that best match the service you want to undertake.</p><div class="form-grid"><div class="form-field form-field--full"><span class="form-label" id="program-label">Primary fellowship program <span class="required" aria-hidden="true">*</span></span><select id="program" name="fellowship_program" required aria-labelledby="program-label"><option value="">Select a program</option><option>Humanity Fellows</option><option>Science Fellows</option><option>Civic Fellows</option><option>Education Fellows</option><option>Earth Fellows</option><option>Innovation Fellows</option><option>International Graduate Fellows</option><option>National Capacity Fellows</option><option>Senior Fellows</option><option>Distinguished Fellows</option></select><p class="field-error" id="program-error">Select a fellowship program.</p></div><div class="form-field form-field--full"><span class="form-label" id="mission-label">Primary mission <span class="required" aria-hidden="true">*</span></span><select id="mission" name="primary_mission" required aria-labelledby="mission-label"><option value="">Select a mission</option><option>Humanity & Human Dignity</option><option>Science & Discovery</option><option>Climate & Planetary Stewardship</option><option>Education & Human Potential</option><option>Immigration & Opportunity</option><option>Civic Life & Public Trust</option><option>Technology for Public Good</option><option>Public Health & Human Security</option><option>National Capacity & Resilience</option><option>Future Generations</option></select><p class="field-error" id="mission-error">Select a primary mission.</p></div><div class="form-field"><label for="appointment-pathway">Preferred appointment pathway</label><select id="appointment-pathway" name="appointment_pathway"><option value="">No preference</option><option>Public-interest appointment</option><option>Research affiliation</option><option>NGO fellowship assignment</option><option>Civic innovation project</option><option>Career Advancement Track</option><option>Advisory fellowship</option><option>Mission fellowship</option></select></div><div class="form-field"><label for="format">Preferred format</label><select id="format" name="preferred_format"><option value="">No preference</option><option>Remote</option><option>In person</option><option>Hybrid</option></select></div><div class="form-field"><label for="start-date">Earliest available start date</label><input type="date" id="start-date" name="available_start_date"></div><div class="form-field"><label for="hours">Hours available per week</label><input type="number" id="hours" name="hours_per_week" min="1" max="80" inputmode="numeric"></div></div></fieldset>
<fieldset class="form-step" data-step="Background" hidden><legend tabindex="-1">Your background</legend><p class="form-help">Provide enough context for reviewers to understand your preparation and field alignment.</p><div class="form-grid"><div class="form-field"><label for="current-role">Current role or title</label><input id="current-role" name="current_role" autocomplete="organization-title"></div><div class="form-field"><label for="organization">Current organization</label><input id="organization" name="organization" autocomplete="organization"></div><div class="form-field"><label for="degree-level">Highest education level</label><select id="degree-level" name="degree_level"><option value="">Select</option><option>High school</option><option>Associate degree</option><option>Bachelor’s degree</option><option>Master’s degree</option><option>Doctoral degree</option><option>Professional degree</option><option>Other</option></select></div><div class="form-field"><label for="field-study">Field of study or expertise <span class="required" aria-hidden="true">*</span></label><input id="field-study" name="field_of_study" required><p class="field-error" id="field-study-error">Enter your field of study or expertise.</p></div><div class="form-field"><label for="school">School or institution</label><input id="school" name="school_name" autocomplete="organization"></div><div class="form-field"><label for="graduation-year">Graduation year</label><input type="number" id="graduation-year" name="graduation_year" min="1940" max="2100" inputmode="numeric"></div><div class="form-field form-field--full"><label for="resume-url">Résumé or CV URL <span class="required" aria-hidden="true">*</span></label><input type="url" id="resume-url" name="resume_url" required placeholder="https://"><p class="field-error" id="resume-url-error">Provide a valid link to your résumé or CV.</p></div><div class="form-field"><label for="linkedin-url">LinkedIn URL</label><input type="url" id="linkedin-url" name="linkedin_url" placeholder="https://"></div><div class="form-field"><label for="portfolio-url">Portfolio, publications, or profile URL</label><input type="url" id="portfolio-url" name="portfolio_url" placeholder="https://"></div><div class="form-field form-field--full"><label for="experience-summary">Relevant experience <span class="required" aria-hidden="true">*</span></label><textarea id="experience-summary" name="experience_summary" required minlength="100" maxlength="3000" aria-describedby="experience-help"></textarea><p id="experience-help">Describe relevant research, service, leadership, projects, advocacy, or professional work in at least 100 characters.</p><p class="field-error" id="experience-summary-error">Provide at least 100 characters about your relevant experience.</p></div></div></fieldset>
<fieldset class="form-step" data-step="Service statement" hidden><legend tabindex="-1">Your service statement</legend><p class="form-help">Explain the public purpose that brings you to the Society.</p><div class="form-grid"><div class="form-field form-field--full"><label for="why-apply">Why do you seek fellowship? <span class="required" aria-hidden="true">*</span></label><textarea id="why-apply" name="why_apply" required minlength="150" maxlength="4000"></textarea><p class="field-error" id="why-apply-error">Provide at least 150 characters.</p></div><div class="form-field form-field--full"><label for="proposed-contribution">What contribution are you prepared to make? <span class="required" aria-hidden="true">*</span></label><textarea id="proposed-contribution" name="proposed_contribution" required minlength="150" maxlength="4000"></textarea><p class="field-error" id="proposed-contribution-error">Provide at least 150 characters.</p></div><div class="form-field form-field--full"><label for="public-benefit">How would your contribution advance the public good? <span class="required" aria-hidden="true">*</span></label><textarea id="public-benefit" name="public_benefit_statement" required minlength="100" maxlength="3000"></textarea><p class="field-error" id="public-benefit-error">Provide at least 100 characters.</p></div><div class="form-field form-field--full"><label for="accommodations">Accessibility accommodations or participation needs <span>(optional)</span></label><textarea id="accommodations" name="accessibility_needs"></textarea></div></div></fieldset>
<fieldset class="form-step" data-step="Review and consent" hidden><legend tabindex="-1">Review and consent</legend><p class="form-help">Review your application, confirm the statements below, and submit.</p><div id="application-review" aria-live="polite"></div><div class="form-note"><p><strong>Privacy notice:</strong> Information submitted through this form is used by authorized program administrators to evaluate fellowship participation, manage applicant records in Dynamics 365, and communicate about your application.</p></div><div style="margin-top:24px"><div class="choice"><input type="checkbox" id="accuracy-consent" name="accuracy_consent" value="yes" required><label for="accuracy-consent">I certify that the information I provided is accurate and complete. <span class="required" aria-hidden="true">*</span></label></div><p class="field-error" id="accuracy-consent-error">Confirm that your application is accurate.</p><div class="choice" style="margin-top:14px"><input type="checkbox" id="service-consent" name="service_consent" value="yes" required><label for="service-consent">I understand that fellowship is selective, participation is not guaranteed, and an appointment carries an obligation to uphold the Code of Service. <span class="required" aria-hidden="true">*</span></label></div><p class="field-error" id="service-consent-error">Confirm your understanding of the fellowship standard.</p><div class="choice" style="margin-top:14px"><input type="checkbox" id="privacy-consent" name="privacy_consent" value="yes" required><label for="privacy-consent">I consent to the collection and processing of this application for fellowship administration. <span class="required" aria-hidden="true">*</span></label></div><p class="field-error" id="privacy-consent-error">Consent is required to submit.</p></div></fieldset>
<div class="form-actions"><button type="button" class="button button--navy" id="application-back" hidden>Back</button><button type="button" class="button button--navy" id="application-next">Continue</button><button type="submit" class="button" id="application-submit" hidden>Submit application</button></div><div class="form-status" id="application-status" role="status" aria-live="polite"></div></form></div></div></section></main>
  <ApplicationScripts />
</BaseLayout>
